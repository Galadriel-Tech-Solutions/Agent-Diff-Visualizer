{
  "name": "agent-diff-visualizer",
  "displayName": "Agent Diff Visualizer",
  "description": "Semantic review workspace for large AI-generated git diffs",
  "version": "0.2.1",
  "publisher": "Galadriel-Tech-Solutions",
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:adv.openReview",
    "onChatParticipant:adv"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "build": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext .ts",
    "vscode:prepublish": "npm run build",
    "package": "npx @vscode/vsce package",
    "publish": "npx @vscode/vsce publish",
    "test": "echo \"No automated tests configured yet\""
  },
  "contributes": {
    "commands": [
      {
        "command": "adv.openReview",
        "title": "ADV: Open Agent Diff Review"
      }
    ],
    "chatParticipants": [
      {
        "id": "adv",
        "name": "adv",
        "description": "Describe your coding intent so Agent Diff Visualizer can map it against your uncommitted changes",
        "isSticky": true,
        "commands": [
          {
            "name": "review",
            "description": "Open the diff review panel using the current intent"
          },
          {
            "name": "clear",
            "description": "Clear the stored intent"
          }
        ]
      }
    ],
    "configuration": {
      "title": "Agent Diff Visualizer",
      "properties": {
        "adv.ollamaModel": {
          "type": "string",
          "default": "",
          "description": "Optional Ollama model name for semantic group labeling. Leave empty to use local heuristics only."
        },
        "adv.maxGroups": {
          "type": "number",
          "default": 8,
          "minimum": 3,
          "maximum": 20,
          "description": "Maximum number of semantic groups to show in review view."
        }
      }
    }
  },
  "keywords": [
    "vscode",
    "extension",
    "git-diff",
    "ai",
    "code-review",
    "local-first"
  ],
  "author": "Yawen Li",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Galadriel-Tech-Solutions/Agent-Diff-Visualizer.git"
  },
  "bugs": {
    "url": "https://github.com/Galadriel-Tech-Solutions/Agent-Diff-Visualizer/issues"
  },
  "homepage": "https://github.com/Galadriel-Tech-Solutions/Agent-Diff-Visualizer#readme",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.116.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^10.2.1",
    "@vscode/vsce": "^3.6.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
